# Copy to .env (or export in your shell) — every value has a working default.

# Which MoMo rails to use. Going live is changing this one line + filling keys below.
#   simulator = local fake MoMo, perfect demo behaviour, no credentials needed
#   mtn       = MTN MoMo Open API (sandbox or production, depending on MTN_* values)
#   airtel    = Airtel Money (stub — see server/momo/airtel.js)
MOMO_PROVIDER=simulator

PORT=3000
# DATA_DIR=./data

# ---- MTN MoMo Open API (https://momodeveloper.mtn.com) ----
# Sandbox: free self-serve. Subscribe to "Collections" and "Disbursements",
# then create an API user+key (see README "Going live").
# MTN_BASE_URL=https://sandbox.momodeveloper.mtn.com
# MTN_TARGET_ENV=sandbox            # 'mtnrwanda' in production
# MTN_COLLECTIONS_SUBSCRIPTION_KEY=
# MTN_DISBURSEMENTS_SUBSCRIPTION_KEY=
# MTN_API_USER=
# MTN_API_KEY=
# MTN_CALLBACK_HOST=https://yourdomain.example

# ---- Airtel Money (https://developers.airtel.africa) ----
# AIRTEL_BASE_URL=https://openapiuat.airtel.africa
# AIRTEL_CLIENT_ID=
# AIRTEL_CLIENT_SECRET=
